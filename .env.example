GROQ_API_KEY=your_groq_api_key_here

# LLM model configuration. Choices: llama-3.1-8b-instant (high rate limits), llama-3.3-70b-versatile, etc.
GROQ_LLM_MODEL=llama-3.1-8b-instant

# Supabase Configurations
VITE_SUPABASE_URL=https://your_supabase_project_ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

USE_CELERY=true

# Gemini API Configurations
# To use Gemini, obtain an API key from Google AI Studio. 
# Leaving this empty will cause the app to automatically fall back to Groq.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LLM_MODEL=gemini-2.5-flash
# Delay in seconds between requests (e.g. 12.0 for free-tier 5 RPM limit, 0 for paid tier)
GEMINI_RATE_LIMIT_SLEEP=12.0